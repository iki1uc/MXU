<script type="module">
  import * as MXU from "./mxu.js";

  // PX sendet TXT hier rein
  function onTXT(txt) {
    const out = MXU.fromPX(txt);
    document.getElementById("out").textContent =
      JSON.stringify(out, null, 2);
  }

  // TESTBUTTON
  document.getElementById("run").addEventListener("click", () => {
    onTXT({ msg: "PX TEST" });
  });
</script>
